config __KCONFIG_SYM__
	bool "__DRIVER_UPPER__ driver (hardware)"
	depends on __DT_HAS_ENABLED__
	select I2C
	help
	  Enable the hardware driver for the __DRIVER_UPPER__.

	  TODO: Update bus selection (I2C, SPI, etc.) to match your device.

config __KCONFIG_SYM___EMUL
	bool "Emulator for __DRIVER_UPPER__"
	depends on __KCONFIG_SYM__ && EMUL
	default y if EMUL
	select I2C_EMUL
	help
	  Build the device emulator. Used by integration tests and SITL.

if __KCONFIG_SYM___EMUL

choice
	prompt "__DRIVER_UPPER__ emulator backend"
	default __KCONFIG_SYM___EMUL_BACKEND_INTEGRATION

config __KCONFIG_SYM___EMUL_BACKEND_INTEGRATION
	bool "Integration (self-contained ztest emulation)"

config __KCONFIG_SYM___EMUL_BACKEND_SITL
	bool "SITL (expose port for Basilisk)"

endchoice

endif
